{
  "ConnectionStrings": {
    "DefaultConnection": "Server=YOURSERVER;Database=YOURDB;User Id=YOURUSER;Password=YOURPASSWORD;TrustServerCertificate=True;MultipleActiveResultSets=True;"
  },
  "Jwt": {
    "Key": "YOUR-LONG-RANDOM-SECRET-AT-LEAST-32-CHARS",
    "Issuer": "TheCertMaster",
    "Audience": "TheCertMasterUsers"
  },
  "Cors": {
    "AllowedOrigins": [
      "https://your-production-site.example"
    ]
  },
  "PublicApp": {
    "BaseUrl": "https://your-production-site.example"
  },
  "Swagger": {
    "Enabled": false
  },
  "HttpsRedirection": {
    "Enabled": false
  },
  "RateLimiting": {
    "AuthAttemptsPerMinute": 8,
    "GuestQuizLoadsPerMinute": 20,
    "AuthenticatedQuizLoadsPerMinute": 60
  }
}
